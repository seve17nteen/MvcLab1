@model IEnumerable<MvcLab1.Models.Workout>

@{
    ViewData["Title"] = ViewBag.Title;
}

<h1>Поиск тренировок</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-auto flex-grow-1">
        <input type="text" name="term" class="form-control" placeholder="Название, тип или инструктор..." value="@ViewBag.SearchTerm">
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm) && !Model.Any())
{
    <div class="alert alert-info">По запросу "@ViewBag.SearchTerm" ничего не найдено</div>
}

@if (Model.Any())
{
    <div class="alert alert-success">Найдено тренировок: @ViewBag.Count</div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5>@item.Name</h5>
                        <p><span class="badge bg-primary">@item.Type</span> <span class="badge bg-secondary">@item.Difficulty</span></p>
                        <p>⏱️ @item.Duration мин | 🔥 @item.Calories ккал | 👨‍🏫 @item.Instructor</p>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">Подробнее</a>
                    </div>
                </div>
            </div>
        }
    </div>
}