@model IEnumerable<MvcLab1.Models.Workout>

@{
    ViewData["Title"] = ViewBag.Title;
}

<h1>@ViewBag.Title</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <label class="form-label">От (мин)</label>
        <input type="number" name="min" class="form-control" value="@ViewBag.MinDuration" step="1">
    </div>
    <div class="col-auto">
        <label class="form-label">До (мин)</label>
        <input type="number" name="max" class="form-control" value="@ViewBag.MaxDuration" step="1">
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-primary">Применить</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">Тренировки не найдены</div>
}
else
{
    <p>Найдено тренировок: @Model.Count()</p>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Название</th>
                <th>Тип</th>
                <th>Длительность</th>
                <th>Калории</th>
                <th>Инструктор</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td
                    <td>@item.Type</td
                    <td>@item.Duration мин</td
                    <td>@item.Calories ккал</td
                    <td>@item.Instructor</td
                    <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a></td
                </tr>
            }
        </tbody>
    </table>
}