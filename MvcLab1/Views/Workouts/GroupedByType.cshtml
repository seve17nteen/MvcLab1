@model IEnumerable<MvcLab1.Models.Workout>
@using System.Linq

@{
    ViewData["Title"] = "Тренировки по типам";
}

<h1>📁 Тренировки по типам</h1>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        Нет тренировок в базе данных
    </div>
}
else
{
    var grouped = Model.GroupBy(w => w.Type)
                       .OrderBy(g => g.Key);

    <div class="accordion" id="typesAccordion">

        @{
            int index = 0;
        }

        @foreach (var group in grouped)
        {
            <div class="accordion-item">

                <h2 class="accordion-header" id="heading@(index)">
                    <button class="accordion-button @(index != 0 ? "collapsed" : "")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapse@(index)"
                            aria-expanded="@(index == 0 ? "true" : "false")"
                            aria-controls="collapse@(index)">

                        <strong>@group.Key</strong>

                        <span class="badge bg-secondary ms-2">
                            @group.Count() тренировок
                        </span>

                    </button>
                </h2>

                <div id="collapse@(index)"
                     class="accordion-collapse collapse @(index == 0 ? "show" : "")"
                     aria-labelledby="heading@(index)"
                     data-bs-parent="#typesAccordion">

                    <div class="accordion-body">

                        <table class="table table-striped table-bordered align-middle">

                            <thead class="table-light">
                                <tr>
                                    <th>Название</th>
                                    <th>Длительность</th>
                                    <th>Калории</th>
                                    <th>Сложность</th>
                                    <th>Инструктор</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var workout in group)
                                {
                                    <tr>
                                        <td>@workout.Name</td>

                                        <td>
                                            @workout.Duration мин
                                        </td>

                                        <td>
                                            @workout.Calories ккал
                                        </td>

                                        <td>
                                            @workout.Difficulty
                                        </td>

                                        <td>
                                            @workout.Instructor
                                        </td>

                                        <td>
                                            <a asp-action="Details"
                                               asp-route-id="@workout.Id"
                                               class="btn btn-sm btn-info">
                                                Детали
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>

                    </div>
                </div>
            </div>

            index++;
        }

    </div>
}
