@model MvcLab1.Models.Workout

@{
    ViewData["Title"] = "Удаление тренировки";
}

<h1>Удаление тренировки</h1>

<div class="alert alert-danger">
    <h3>Вы уверены, что хотите удалить эту тренировку?</h3>
</div>

<hr />

<dl class="row">

    <dt class="col-sm-3">Название</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Тип</dt>
    <dd class="col-sm-9">@Model.Type</dd>

    <dt class="col-sm-3">Длительность</dt>
    <dd class="col-sm-9">@Model.Duration мин</dd>

    <dt class="col-sm-3">Калории</dt>
    <dd class="col-sm-9">@Model.Calories</dd>

</dl>

<form asp-action="Delete">

    <input type="hidden" asp-for="Id" />

    <input type="submit" value="Удалить" class="btn btn-danger" />

    <a asp-action="Index" class="btn btn-secondary">Отмена</a>

</form>
