@model IEnumerable<MvcLab1.Models.Workout>

@{
    ViewData["Title"] = "Управление тренировками";
}

<h1>Управление тренировками</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить тренировку</a>
</p>

<table class="table table-striped table-hover">

    <thead>
        <tr>
            <th>Id</th>
            <th>Название</th>
            <th>Тип</th>
            <th>Длительность</th>
            <th>Калории</th>
            <th>Сложность</th>
            <th>Инструктор</th>
            <th>Дата</th>
            <th>Действия</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Type</td>
                <td>@item.Duration мин</td>
                <td>@item.Calories</td>
                <td>@item.Difficulty</td>
                <td>@item.Instructor</td>
                <td>@item.Date.ToShortDateString()</td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Детали</a>

                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Изменить</a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Удалить</a>
                </td>

            </tr>
        }

    </tbody>
</table>
