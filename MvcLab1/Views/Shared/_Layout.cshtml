<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MvcLab1</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MvcLab1.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MvcLab1</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1" style="flex-direction: row; gap: 20px;">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Products" asp-action="Index">Товары</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Workouts" asp-action="Index">Воркаут</a>
                        </li>

                        <!-- ВЫПАДАЮЩЕЕ МЕНЮ ДЛЯ LINQ-ЗАПРОСОВ -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                📊 LINQ-запросы
                            </a>
                            <ul class="dropdown-menu">
                                <!-- Заголовок для товаров -->
                                <li><h6 class="dropdown-header text-primary">📦 Товары</h6></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="ByPrice">💰 Фильтр по цене</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="TopExpensive">🏆 Топ дорогих</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Search">🔍 Поиск</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="GroupedByCategory">📁 Группировка по категориям</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Statistics">📊 Статистика</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Paginated">📄 Пагинация</a></li>

                                <li><hr class="dropdown-divider"></li>

                                <!-- Заголовок для тренировок -->
                                <li><h6 class="dropdown-header text-success">🏋️ Тренировки</h6></li>
                                <li><a class="dropdown-item" asp-controller="Workouts" asp-action="ByDuration">⏱️ Фильтр по длительности</a></li>
                                <li><a class="dropdown-item" asp-controller="Workouts" asp-action="TopCalorieBurning">🔥 Топ калорийных</a></li>
                                <li><a class="dropdown-item" asp-controller="Workouts" asp-action="Search">🔍 Поиск</a></li>
                                <li><a class="dropdown-item" asp-controller="Workouts" asp-action="GroupedByType">📁 Группировка по типам</a></li>
                                <li><a class="dropdown-item" asp-controller="Workouts" asp-action="Statistics">📊 Статистика</a></li>
                                <li><a class="dropdown-item" asp-controller="Workouts" asp-action="Paginated">📄 Пагинация</a></li>
                            </ul>
                        </li>
                        <!-- КОНЕЦ МЕНЮ LINQ-ЗАПРОСОВ -->

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MvcLab1 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>