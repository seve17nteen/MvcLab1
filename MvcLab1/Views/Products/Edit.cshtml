@model MvcLab1.Models.Product
@{
    ViewData["Title"] = "Редактирование товара";
}
<h1>Редактирование товара</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" />
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
<textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="InStock" class="form-check-input" />
                <label asp-for="InStock" class="form-check-label"></label>
            </div>
            <div class="mb-3">
                <label asp-for="CreatedDate" class="form-label"></label>
                <input asp-for="CreatedDate" class="form-control" type="date"
                       disabled="disabled" />
                <span class="text-muted">Дату создания изменить нельзя</span>
            </div>
            <div class="mb-3">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Информация</h5>
            </div>
            <div class="card-body">
                <p>Редактирование товара <strong>@Model.Name</strong></p>
                <p>ID товара: @Model.Id</p>
                <p>
                    Цена со скидкой 10%:
                    <strong>@Model.GetDiscountedPrice(10).ToString("C")</strong>
                </p>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Дополнительная валидация на клиенте
        $(document).ready(function () {
        // Подсветка обязательных полей
        $('input[required], textarea[required]').addClass('border-primary');
        });
    </script>
}