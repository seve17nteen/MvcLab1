@model IEnumerable<MvcLab1.Models.Product>

@{
    ViewData["Title"] = ViewBag.Title;
}

<h1>Поиск товаров</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-auto flex-grow-1">
        <input type="text" name="term" class="form-control" placeholder="Введите поисковый запрос..." value="@ViewBag.SearchTerm">
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm) && !Model.Any())
{
    <div class="alert alert-info">По запросу "@ViewBag.SearchTerm" ничего не найдено</div>
}

@if (Model.Any())
{
    <div class="alert alert-success">Найдено товаров: @ViewBag.Count</div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="card-text text-muted">@item.Category</p>
                        <p class="card-text">@item.Price.ToString("C")</p>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Подробнее</a>
                    </div>
                </div>
            </div>
        }
    </div>
}