@model IEnumerable<MvcLab1.Models.Product>

@{
    ViewData["Title"] = ViewBag.Title;
}

<h1>@ViewBag.Title</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <label class="form-label">От (₽)</label>
        <input type="number" name="min" class="form-control" placeholder="Мин. цена" value="@ViewBag.MinPrice" step="0.01">
    </div>
    <div class="col-auto">
        <label class="form-label">До (₽)</label>
        <input type="number" name="max" class="form-control" placeholder="Макс. цена" value="@ViewBag.MaxPrice" step="0.01">
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-primary">Применить</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">Товары не найдены</div>
}
else
{
    <p>Найдено товаров: @Model.Count()</p>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>В наличии</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td
                    <td>@item.Category</td
                    <td>@item.Price.ToString("C")</td
                    <td>@(item.InStock ? "Да" : "Нет")</td
                    <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a></td
                </tr>
            }
        </tbody>
    </table>
}