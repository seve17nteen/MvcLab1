@model IEnumerable<MvcLab1.Models.Product>

@{
    ViewData["Title"] = ViewBag.Title;
}

<h1>@ViewBag.Title</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <label class="form-label">Количество товаров</label>
        <input type="number" name="count" class="form-control" value="@ViewBag.Count" min="1" max="20" step="1">
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-primary">Показать</button>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        Нет товаров в базе данных. Добавьте товары через <a asp-action="Create">форму создания</a>.
    </div>
}
else
{
    <div class="alert alert-info">
        <strong>Топ @ViewBag.Count самых дорогих товаров</strong>
    </div>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>В наличии</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @{
                int rank = 1;
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@(rank++)</strong></td>
                    <td>@item.Name</td>
                    <td>@item.Category</td>
                    <td class="text-danger fw-bold">@item.Price.ToString("C")</td>
                    <td>@(item.InStock ? "Да" : "Нет")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}